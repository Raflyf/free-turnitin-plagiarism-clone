# Plagiarism Checker - Konfigurasi API
# Rename file ini menjadi `.env` lalu isi dengan API Key asli Anda

# ==========================================
# WAJIB UNTUK PENELUSURAN INTERNET STANDAR
# ==========================================

# 1. Google Custom Search (Gratis 10k/hari)
# Pisahkan multiple keys dengan koma
GOOGLE_API_KEYS=
GOOGLE_CX_ID=

# 2. ScrapingBee (Bypass CAPTCHA Google biasa)
SCRAPINGBEE_KEY=

# 3. ScraperAPI (Alternatif bypass CAPTCHA)
SCRAPERAPI_KEY=

# ==========================================
# WAJIB UNTUK AI SEMANTIC SEARCH (OPSIONAL TAPI SANGAT DISARANKAN)
# ==========================================

# Gemini API Keys (Pisahkan dengan koma untuk Load Balancing)
GEMINI_KEYS=

# Perplexity API
PERPLEXITY_KEY=

# Cohere API
COHERE_KEY=

# Tavily API
TAVILY_KEY=

# Abstract API (Bypass blokir repositori)
ABSTRACT_KEY=

# ==========================================
# LAIN-LAIN
# ==========================================
# Set ke 'true' jika ingin mengekspos server lokal ke publik via Ngrok
USE_NGROK=false
